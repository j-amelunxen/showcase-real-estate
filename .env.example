IMPRESSUM_CITY="12345 Musterstadt"
IMPRESSUM_PHONE="+49 000 0000000"
IMPRESSUM_EMAIL="impressum@example.com"
IMPRESSUM_VAT="DE000000000"
IMPRESSUM_WEB="example.com"
